# Dependency directories
node_modules/
client/node_modules/
server/node_modules/

# Environment files (contains sensitive API keys and secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
server/.env

# Production build outputs
dist/
client/dist/
build/
client/build/
out/

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# IDEs and editor configurations
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.eslintcache

# Operating System files
.DS_Store
Thumbs.db
desktop.ini

# User-uploaded files (keep the folder structure but ignore uploads)
server/public/uploads/*
!server/public/uploads/.gitkeep
